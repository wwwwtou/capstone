@startuml logical-architecture
title Logical Architecture - E-commerce Video Recommendation System

skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultTextAlignment center

actor "Admin / Operator" as admin
actor "Terminal User\n(consumer)" as user

package "Presentation Layer" {
  [React Dashboard (Vite SPA)\nAdmin: DashboardHome, Monitoring,\nAlgoConfig, Simulator\nConsumer: For You Feed] as react
}

package "Edge / BFF Layer" {
  [Node server.ts\n(dual-mode: in-memory mock replica\nOR reverse-proxy to gateway)\n+ demo traffic generator\n+ edge metrics] as bff
}

package "API Gateway Layer (Go)" {
  [API Gateway] as gw
  note right of gw
    Cross-cutting concerns:
    * JWT auth (HS256, stdlib) on writes
    * Per-IP rate limiter -> 429
    * Circuit breaker per downstream -> 503
    * Health aggregation
    * X-Request-ID assignment / tracing
    * /api/v1/metrics aggregation
      (scrapes downstream /metricsz)
  end note
}

package "Domain Services (Go microservices)" {
  [Recommendation Service\n(clean arch: domain/app/infra/transport;\nStrategy + Factory ranking;\nbreaker + retry + cold-start fallback)] as rec
  [User Profile Service\n(interactions, profile aggregation,\ncache hit/miss metrics)] as usvc
  [Content Service\n(video candidates)] as csvc
}

package "Data Layer" {
  database "PostgreSQL\n(database-per-service)" as pg {
    [user_db]
    [content_db]
    [rec_db]
  }
  database "Redis\n(profile cache, key-value)" as redis
}

admin --> react
user --> react : For You Feed\n(view/like events)
react --> bff : /api/v1/*  (same-origin)
bff --> gw : proxy (full-stack mode)

gw --> rec
gw --> usvc
gw --> csvc

rec --> usvc : profile (internal, resilient)
rec --> csvc : candidates (internal, resilient)
rec --> rec_db
usvc --> user_db
usvc --> redis
csvc --> content_db

note bottom of react
  Consumer closed loop: view/like ->
  POST /users/{id}/interactions ->
  profile cache invalidated ->
  re-ranked feed on refresh
end note

note bottom of csvc
  Observability: every Go service exposes
  /metrics (Prometheus text) + /metricsz (JSON);
  breaker states exported as gauges;
  one X-Request-ID traces the whole chain
end note
@enduml
