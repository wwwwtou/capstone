# Web/frontend server (server.ts)

# Local full-stack mode: point the web server at the microservice gateway so the
# UI talks to the real Go microservices + Postgres + Redis.
# Leave this UNSET to serve the lightweight in-memory mock instead (this is what
# the single-service online deploy on Render uses).
GATEWAY_URL=http://localhost:8080

# Port the web/frontend server listens on.
PORT=3000

# Shared secret used by the gateway to sign/verify JWTs. Must match the value
# passed to the gateway service (see tiktok-glocal-ecommerce-recsys-mvp/docker-compose.yml).
JWT_SECRET=defense-secret-2026
